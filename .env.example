ANSWER_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
RERANKER_BACKEND=cross_encoder
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

RETRIEVAL_TOP_K_LEXICAL=12
RETRIEVAL_TOP_K_VECTOR=12
RETRIEVAL_TOP_K_RERANK=5
MIN_RERANK_SCORE_TO_ANSWER=0.10
MMR_DIVERSITY_FACTOR=0.3
QUERY_NORMALIZATION_ENABLED=true
NLI_VERIFIER_ENABLED=false

REQUEST_TIMEOUT_SECONDS=20.0
USER_AGENT=CollegeAdmissionAssistant/0.2 (official-rag)

PUBLIC_SIGNALS_ENABLED=false
CACHE_TTL_SECONDS=86400
RESULT_CACHE_ENABLED=true
REDDIT_LIMIT=8
YOUTUBE_LIMIT=10
YOUTUBE_MAX_RESULTS=15

LOG_LEVEL=INFO
APP_VERSION=1.0.0

INDEX_SCHEMA_VERSION=1.0.0
TRACING_ENABLED=false
METRICS_ENABLED=false
